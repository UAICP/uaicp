{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uaicp.org/schema/verification-report.schema.json",
  "title": "UAICP Verification Report",
  "type": "object",
  "required": [
    "report_id",
    "request_id",
    "status",
    "checks",
    "generated_at"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "minLength": 1
    },
    "request_id": {
      "type": "string",
      "format": "uuid"
    },
    "verifier_id": {
      "type": "string",
      "minLength": 1,
      "description": "Identity of the verification engine or user"
    },
    "evidence_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "The evidence objects consumed by this verifier"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "partial"
      ]
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "check_id",
          "result"
        ],
        "properties": {
          "check_id": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "skip"
            ]
          },
          "details": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}