{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uaicp.org/schema/message-envelope.schema.json",
  "title": "UAICP Message Envelope",
  "type": "object",
  "required": [
    "uaicp_version",
    "request_id",
    "trace_id",
    "state",
    "timestamp",
    "identity",
    "outcome"
  ],
  "properties": {
    "uaicp_version": {
      "type": "string"
    },
    "request_id": {
      "type": "string",
      "format": "uuid"
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "parent_trace_id": {
      "type": "string",
      "minLength": 1,
      "description": "Optional trace ID of the parent orchestrator or agent for nested swarms"
    },
    "state": {
      "type": "string",
      "enum": [
        "intake",
        "plan",
        "execute",
        "verify",
        "deliver",
        "fail_safe"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "identity": {
      "type": "object",
      "required": [
        "agent_id",
        "owner_id",
        "control_class"
      ],
      "properties": {
        "agent_id": {
          "type": "string",
          "minLength": 1
        },
        "owner_id": {
          "type": "string",
          "minLength": 1
        },
        "user_id": {
          "type": "string",
          "minLength": 1
        },
        "control_class": {
          "type": "string",
          "enum": [
            "autonomous",
            "human-supervised",
            "human-directed"
          ]
        }
      },
      "additionalProperties": true
    },
    "outcome": {
      "type": "string",
      "enum": [
        "success",
        "failure",
        "uncertain",
        "pending"
      ]
    },
    "streaming": {
      "type": "object",
      "properties": {
        "chunk_id": {
          "type": "string"
        },
        "is_final": {
          "type": "boolean"
        },
        "stream_index": {
          "type": "integer"
        }
      },
      "additionalProperties": true,
      "description": "Metadata for partial UX streaming execution"
    },
    "rollback_action": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "payload": {
          "type": [
            "object",
            "string"
          ]
        }
      },
      "additionalProperties": true,
      "description": "Structured rollback metadata for high-risk write operations"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}